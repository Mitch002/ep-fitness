{
	"landingPage": "/",
	"preferredVersions": {
		"php": "8.2",
		"wp": "6.9"
	},
	"steps": [
		{
			"step": "writeFile",
			"path": "/wordpress/wp-content/themes/ep-fitness/style.css",
			"data": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/Mitch002/ep-fitness/main/themes/ep-fitness/style.css"
			}
		},
		{
			"step": "installTheme",
			"themeData": {
				"resource": "url",
				"url": "https://github-proxy.com/proxy/?repo=Mitch002/ep-fitness&branch=main&directory=themes/ep-fitness"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "defineWpConfigConsts",
			"consts": {
				"WP_HOME": "https://playground.wordpress.net",
				"WP_SITEURL": "https://playground.wordpress.net"
			}
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/Mitch002/ep-fitness/main/content-export.xml"
			}
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "EP Fitness",
				"blogdescription": "Wichita's Premier Personal Training",
				"show_on_front": "page",
				"page_on_front": "5",
				"permalink_structure": "/%postname%/"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require_once 'wordpress/wp-load.php'; global $wpdb; $wpdb->query(\"UPDATE {$wpdb->posts} SET post_content = REPLACE(post_content, 'http://ep-fitness.local', '') WHERE post_content LIKE '%ep-fitness.local%'\"); $wpdb->query(\"UPDATE {$wpdb->posts} SET guid = REPLACE(guid, 'http://ep-fitness.local', '') WHERE guid LIKE '%ep-fitness.local%'\"); echo 'URLs updated';"
		}
	]
}
