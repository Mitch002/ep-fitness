		{
			"step": "activateTheme",
			"themeFolderName": "ep-fitness"
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://raw.githubusercontent.com/Mitch002/ep-fitness/main/content-export.xml"
			}
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "EP Fitness",
				"blogdescription": "Wichita's Premier Personal Training",
				"show_on_front": "page",
				"page_on_front": "5",
				"permalink_structure": "/%postname%/"
			}
		},
		{
			"step": "runPHP",
			"code": "<?php require_once 'wordpress/wp-load.php'; global $wpdb; $wpdb->query(\"UPDATE {$wpdb->posts} SET post_content = REPLACE(post_content, 'http://ep-fitness.local/wp-content/uploads/', '/wp-content/uploads/') WHERE post_content LIKE '%ep-fitness.local%'\"); $wpdb->query(\"UPDATE {$wpdb->posts} SET guid = REPLACE(guid, 'http://ep-fitness.local/wp-content/uploads/', '/wp-content/uploads/') WHERE guid LIKE '%ep-fitness.local%'\"); echo 'URLs updated';"
		}
	]
}
